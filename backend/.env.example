# Port and Host for Uvicorn
PORT=8000
HOST=0.0.0.0

# Choose LLM provider: 'gemini' or 'openai'
LLM_PROVIDER=gemini

# If provider is 'gemini', set your Gemini API key:
GEMINI_API_KEY=

# If provider is 'openai', set your OpenAI API key:
OPENAI_API_KEY=

# Model configuration
GEMINI_MODEL=gemini-2.5-flash
OPENAI_MODEL=gpt-4o-mini

# Slack configurations (needed for Step 3 event integration)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
SLACK_SIGNING_SECRET=your-slack-signing-secret-here

